generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TicketStatus {
  OPEN
  CLAIMED
  CLOSED
}

model GuildConfig {
  id                  String       @id @default(cuid())
  guildId             String       @unique
  supportRoleId       String
  logChannelId        String?
  ticketCategoryId    String?
  panelChannelId      String?
  transcriptRetention Int          @default(30)
  ticketTypes         TicketType[]
  tickets             Ticket[]
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  @@index([guildId])
}

model TicketType {
  id          String      @id @default(cuid())
  guildId     String
  name        String
  description String?
  emoji       String?
  guild       GuildConfig @relation(fields: [guildId], references: [guildId], onDelete: Cascade)

  @@unique([guildId, name])
}

model User {
  id        String   @id @default(cuid())
  discordId String   @unique
  username  String?
  tickets   Ticket[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Ticket {
  id             String       @id @default(cuid())
  guildId        String
  channelId      String       @unique
  openerId       String
  type           String?
  status         TicketStatus @default(OPEN)
  claimedById    String?
  closeReason    String?
  transcriptPath String?
  createdAt      DateTime     @default(now())
  closedAt       DateTime?
  updatedAt      DateTime     @updatedAt
  guild          GuildConfig  @relation(fields: [guildId], references: [guildId], onDelete: Cascade)
  opener         User         @relation(fields: [openerId], references: [discordId], onDelete: Cascade)
  messages       TicketMessage[]

  @@index([guildId, status, createdAt])
  @@index([openerId, status])
}

model TicketMessage {
  id         String   @id @default(cuid())
  ticketId   String
  authorId   String
  authorName String
  authorIcon String?
  content    String
  createdAt  DateTime @default(now())
  ticket     Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId, createdAt])
}
